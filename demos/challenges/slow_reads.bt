//   Timestamp kaydedin: @start[tid] = nsecs;


// TODO: tracepoint:syscalls:sys_exit_read  (filtre: /@start[tid]/)
//   Delta hesaplayin: $delta = nsecs - @start[tid];
//   $delta > 1000000 ise pid, comm ve latency'yi yazdirin
//   Temizleyin: delete(@start[tid]);
