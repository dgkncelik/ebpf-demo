#!/usr/bin/env bpftrace
/*
 * file_spy.bt — Sistem genelinde dosya acma islemlerini izler.
 * PID, process adi ve acilan dosyayi gosterir.
 *
 * Kullanim: sudo bpftrace file_spy.bt
 */

BEGIN
{
    printf("Dosya acma islemleri izleniyor... Ctrl+C ile durdurun.\n");
    printf("%-6s %-16s %s\n", "PID", "COMM", "FILENAME");
}

tracepoint:syscalls:sys_enter_openat
{
    printf("%-6d %-16s %s\n", pid, comm, str(args.filename));
}
